# Template for a native build that points at a LOCAL backend (your machine).
# Copy to .env.androidlocal (git-ignored) and set your machine's LAN IP.
# Loaded by: vite build --mode androidlocal  (npm run build:android:local)
#
# Use your LAN IP, NOT localhost: inside the device webview "localhost" is the
# phone, not your computer. Find it with `ip addr` / `ifconfig` (e.g. 192.168.x.x).
# Android blocks cleartext http:// by default, so a local http backend also needs
# server.cleartext or a network-security-config (see OPS.md).
VITE_GOOGLE_CLIENT_ID=823603281404-rgg8sb970f86cmqo91vgi6ibh0ph8ban.apps.googleusercontent.com
VITE_API_BASE=http://192.168.1.50:3100
